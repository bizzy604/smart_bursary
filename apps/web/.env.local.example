# NextAuth secret used to sign and encrypt session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL the browser uses to talk to the NestJS API.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Optional: explicit URL Auth.js redirects to. Leave unset for local dev to
# auto-detect from the request, or set in production deployments.
# AUTH_URL=https://app.example.com
